DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://*.vercel.app
